{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the app windows",
  "windows": [
    "main",
    "overlay",
    "editor"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-close",
    "opener:default",
    "dialog:default",
    "drag:default"
  ]
}